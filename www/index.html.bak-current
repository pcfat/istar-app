<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>星進教育 i-STAR Education</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: #1AABE0;
        }
        .loading {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #1AABE0;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        .spinner {
            border: 4px solid rgba(255,255,255,0.3);
            border-top: 4px solid white;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="loading">
        <div class="spinner"></div>
        <p>載入中...</p>
    </div>
    
    <script src="capacitor.js"></script>
    <script>
        // Wait for Capacitor to be ready
        document.addEventListener('deviceready', async function() {
            try {
                const { Browser } = Capacitor.Plugins;
                await Browser.open({
                    url: 'https://s.istars.hk/app/index.php',
                    presentationStyle: 'fullscreen'
                });
            } catch (error) {
                console.error('Failed to open browser:', error);
                // Fallback: redirect
                window.location.href = 'https://s.istars.hk/app/index.php';
            }
        });
        
        // Fallback: if Capacitor doesn't fire deviceready in 2 seconds
        setTimeout(function() {
            window.location.href = 'https://s.istars.hk/app/index.php';
        }, 2000);
    </script>
</body>
</html>
